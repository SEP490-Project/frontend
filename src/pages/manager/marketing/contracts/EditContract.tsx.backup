import React, { useState, useEffect } from "react";
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from "@/components/ui/card";
import { useAppDispatch } from "@/libs/stores";
import { getContractById } from "@/libs/stores/contractManager/thunk";
import { useNavigate, useParams } from "react-router-dom";
import { motion } from "framer-motion";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Textarea } from "@/components/ui/textarea";
import { Label } from "@/components/ui/label";
import { Badge } from "@/components/ui/badge";
import { FaArrowLeft, FaSave } from "react-icons/fa";
import { Loader2 } from "lucide-react";
import { useContract } from "@/libs/hooks/useContract";
import { format } from "date-fns";
import { DatePicker } from "@/components/date-picker";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";
import { Tabs, TabsList, TabsTrigger, TabsContent } from "@/components/ui/tabs";
import { toast } from "sonner";

const CONTRACT_TYPE_OPTIONS = [
  { value: "ADVERTISING", label: "Advertising Contract" },
  { value: "AFFILIATE", label: "Affiliate Marketing" },
  { value: "BRAND_AMBASSADOR", label: "Brand Ambassador" },
  { value: "CO_PRODUCING", label: "Co-Production" },
];

const CONTRACT_TYPE_COLORS = {
  ADVERTISING: { bg: "bg-orange-100", text: "text-orange-800", border: "border-orange-200" },
  AFFILIATE: { bg: "bg-blue-100", text: "text-blue-800", border: "border-blue-200" },
  BRAND_AMBASSADOR: {
    bg: "bg-emerald-100",
    text: "text-emerald-800",
    border: "border-emerald-200",
  },
  CO_PRODUCING: { bg: "bg-violet-100", text: "text-violet-800", border: "border-violet-200" },
} as const;

const EditContractPage: React.FC = () => {
  const { id } = useParams<{ id: string }>();
  const [activeTab, setActiveTab] = useState<string>("basic");
  
  // Basic Information
  const [title, setTitle] = useState("");
  const [contractType, setContractType] = useState("");
  const [signedDate, setSignedDate] = useState("");
  const [signedLocation, setSignedLocation] = useState("");
  const [startDate, setStartDate] = useState("");
  const [endDate, setEndDate] = useState("");
  const [depositPercent, setDepositPercent] = useState(0);
  const [depositAmount, setDepositAmount] = useState(0);
  
  // Representative Information
  const [repName, setRepName] = useState("");
  const [repRole, setRepRole] = useState("");
  const [repPhone, setRepPhone] = useState("");
  const [repEmail, setRepEmail] = useState("");
  const [repTaxNumber, setRepTaxNumber] = useState("");
  const [repBankName, setRepBankName] = useState("");
  const [repBankAccount, setRepBankAccount] = useState("");
  const [repBankHolder, setRepBankHolder] = useState("");
  
  // Brand Information (Read-only)
  const [brandInfo, setBrandInfo] = useState<any>(null);
  
  const [isLoading, setIsLoading] = useState(true);

  const dispatch = useAppDispatch();
  const navigate = useNavigate();
  const { contractDetail, detailLoading } = useContract();

  // Load contract data
  useEffect(() => {
    if (id) {
      dispatch(getContractById(id));
    }
  }, [dispatch, id]);

  // Populate form when contract data loads
  useEffect(() => {
    if (contractDetail && !detailLoading) {
      setTitle(contractDetail.title || "");
      setContractType(contractDetail.type || "");
      setSignedDate(
        contractDetail.signed_date
          ? format(new Date(contractDetail.signed_date), "yyyy-MM-dd")
          : ""
      );
      setSignedLocation(contractDetail.signed_location || "");
      setStartDate(
        contractDetail.start_date
          ? format(new Date(contractDetail.start_date), "yyyy-MM-dd")
          : ""
      );
      setEndDate(
        contractDetail.end_date ? format(new Date(contractDetail.end_date), "yyyy-MM-dd") : ""
      );
      setDepositPercent(contractDetail.deposit_percent || 0);
      setDepositAmount(contractDetail.deposit_amount || 0);
      
      // Representative info
      setRepName(contractDetail.representative_name || "");
      setRepRole(contractDetail.representative_role || "");
      setRepPhone(contractDetail.representative_phone || "");
      setRepEmail(contractDetail.representative_email || "");
      setRepTaxNumber(contractDetail.representative_tax_number || "");
      setRepBankName(contractDetail.representative_bank_name || "");
      setRepBankAccount(contractDetail.representative_bank_account_number || "");
      setRepBankHolder(contractDetail.representative_bank_account_holder || "");

      // Brand info (read-only)
      if (contractDetail.brand) {
        setBrandInfo({
          id: contractDetail.brand.id,
          name: contractDetail.brand.name,
          address: contractDetail.brand.address,
          representative_name: contractDetail.brand.representative_name,
          representative_role: contractDetail.brand.representative_role,
          contact_phone: contractDetail.brand.contact_phone,
          contact_email: contractDetail.brand.contact_email,
          tax_number: contractDetail.brand.tax_number,
          bank_name: contractDetail.brand.bank_name,
          bank_account_number: contractDetail.brand.bank_account_number,
          bank_account_holder: contractDetail.brand.bank_account_holder,
        });
      }

      setIsLoading(false);
    }
  }, [contractDetail, detailLoading]);

  const handleSubmit = async () => {
    if (!title || !startDate || !endDate) {
      toast.error("Please fill in all required fields");
      return;
    }

    // TODO: Implement update contract API call
    const payload = {
      title,
      type: contractType,
      signed_date: signedDate ? new Date(signedDate).toISOString() : "",
      signed_location: signedLocation,
      start_date: startDate ? new Date(startDate).toISOString() : "",
      end_date: endDate ? new Date(endDate).toISOString() : "",
      deposit_percent: depositPercent,
      deposit_amount: depositAmount,
      representative_name: repName,
      representative_role: repRole,
      representative_phone: repPhone,
      representative_email: repEmail,
      representative_tax_number: repTaxNumber,
      representative_bank_name: repBankName,
      representative_bank_account_number: repBankAccount,
      representative_bank_account_holder: repBankHolder,
    };

    console.log("Contract update payload:", payload);
    toast.success("Contract updated successfully (simulated)");

    // Simulate success
    setTimeout(() => {
      navigate(`/manage/marketing/contracts/${id}`);
    }, 500);
  };

  const handleGoBack = () => {
    navigate(`/manage/marketing/contracts/${id}`);
  };

  // Animation variants
  const itemVariants = {
    hidden: { opacity: 0, y: 20 },
    visible: { opacity: 1, y: 0 },
  };

  const containerVariants = {
    hidden: { opacity: 0 },
    visible: {
      opacity: 1,
      transition: { staggerChildren: 0.1 },
    },
  };

  if (isLoading || detailLoading) {
    return (
      <div className="min-h-screen flex items-center justify-center">
        <div className="flex flex-col items-center gap-2">
          <Loader2 className="h-8 w-8 animate-spin text-primary" />
          <p className="text-gray-600">Loading contract details...</p>
        </div>
      </div>
    );
  }

  if (!contractDetail) {
    return (
      <div className="min-h-screen flex items-center justify-center">
        <div className="text-center">
          <h2 className="text-xl font-semibold text-gray-900 mb-2">Contract not found</h2>
          <p className="text-gray-600 mb-4">The contract you're trying to edit doesn't exist.</p>
          <Button onClick={() => navigate("/manage/marketing/contracts")}>Go to Contracts</Button>
        </div>
      </div>
    );
  }

  const isValid = !!title && !!startDate && !!endDate && !!contractType;
  const contractTypeColor = CONTRACT_TYPE_COLORS[contractType as keyof typeof CONTRACT_TYPE_COLORS] || {
    bg: "bg-gray-100",
    text: "text-gray-800",
    border: "border-gray-200",
  };

  return (
    <div className="min-h-fit p-4 sm:p-6 max-w-7xl mx-auto">
      <motion.div
        variants={containerVariants}
        initial="hidden"
        animate="visible"
        className="space-y-6"
      >
        {/* Header */}
        <motion.div variants={itemVariants} className="flex items-center justify-between mb-6">
          <div className="flex items-center gap-3">
            <Button variant="ghost" onClick={handleGoBack} className="flex items-center">
              <FaArrowLeft className="w-4 h-4 mr-2" />
              Return
            </Button>

            <div>
              <h1 className="text-2xl font-bold text-gray-900 flex items-center gap-2">
                Edit Contract
              </h1>
              <p className="text-gray-600">Update contract information and terms</p>
            </div>
          </div>

          <Button onClick={handleSubmit} disabled={!isValid}>
            <FaSave className="mr-2" />
            Save Changes
          </Button>
        </motion.div>

        {/* Contract Status & Type */}
        <motion.div variants={itemVariants} className="flex items-center gap-3">
          <Badge className={`${contractTypeColor.bg} ${contractTypeColor.text} border ${contractTypeColor.border} px-3 py-1`}>
            {CONTRACT_TYPE_OPTIONS.find(opt => opt.value === contractType)?.label || contractType}
          </Badge>
          <Badge variant="outline" className="capitalize">
            Contract #{contractDetail.contract_number}
          </Badge>
          <Badge variant={contractDetail.status === "ACTIVE" ? "default" : "secondary"}>
            {contractDetail.status}
          </Badge>
        </motion.div>

        {/* Brand Information (Read-only) */}
        {brandInfo && (
          <motion.div variants={itemVariants}>
            <Card>
              <CardHeader>
                <CardTitle className="text-lg font-semibold">Brand Information</CardTitle>
                <CardDescription>
                  Contract is associated with this brand (read-only)
                </CardDescription>
              </CardHeader>
              <CardContent className="space-y-4">
                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <Label className="text-sm font-medium text-gray-600">Brand Name</Label>
                    <div className="mt-1 p-3 bg-gray-50 rounded-lg border">
                      <p className="text-sm font-medium">{brandInfo.name}</p>
                    </div>
                  </div>

                  <div>
                    <Label className="text-sm font-medium text-gray-600">Address</Label>
                    <div className="mt-1 p-3 bg-gray-50 rounded-lg border">
                      <p className="text-sm">{brandInfo.address}</p>
                    </div>
                  </div>

                  <div>
                    <Label className="text-sm font-medium text-gray-600">Representative</Label>
                    <div className="mt-1 p-3 bg-gray-50 rounded-lg border">
                      <p className="text-sm font-medium">{brandInfo.representative_name}</p>
                      <p className="text-xs text-gray-500">{brandInfo.representative_role}</p>
                    </div>
                  </div>

                  <div>
                    <Label className="text-sm font-medium text-gray-600">Contact</Label>
                    <div className="mt-1 p-3 bg-gray-50 rounded-lg border">
                      <p className="text-sm">{brandInfo.contact_phone}</p>
                      <p className="text-xs text-gray-500">{brandInfo.contact_email}</p>
                    </div>
                  </div>
                </div>

                <div className="p-3 bg-blue-50 border border-blue-200 rounded-lg">
                  <p className="text-sm text-blue-800">
                    <strong>Note:</strong> Brand information cannot be changed. Contract type is also locked after creation.
                  </p>
                </div>
              </CardContent>
            </Card>
          </motion.div>
        )}

        {/* Tabs for editing sections */}
        <motion.div variants={itemVariants}>
          <Card>
            <CardContent className="p-6">
              <Tabs value={activeTab} onValueChange={setActiveTab}>
                <TabsList className="grid w-full grid-cols-3 bg-white/70 backdrop-blur-sm mb-6">
                  <TabsTrigger value="basic">Basic Information</TabsTrigger>
                  <TabsTrigger value="representative">Representative Info</TabsTrigger>
                  <TabsTrigger value="terms">Contract Terms</TabsTrigger>
                </TabsList>

                {/* Basic Information Tab */}
                <TabsContent value="basic" className="space-y-5">
                  <div>
                    <Label className="text-sm font-medium">Contract Title *</Label>
                    <Input
                      placeholder="e.g. Product Advertising Agreement 2024"
                      value={title}
                      onChange={(e) => setTitle(e.target.value)}
                      className="h-11 mt-1"
                    />
                  </div>

                  <div>
                    <Label className="text-sm font-medium">Contract Type</Label>
                    <Input
                      value={CONTRACT_TYPE_OPTIONS.find(opt => opt.value === contractType)?.label || contractType}
                      readOnly
                      className="h-11 mt-1 bg-gray-50 text-gray-500"
                    />
                    <p className="text-xs text-muted-foreground mt-1">
                      Contract type cannot be changed after creation
                    </p>
                  </div>

                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                      <DatePicker
                        label="Signed Date *"
                        value={signedDate}
                        onChange={setSignedDate}
                        placeholder="Select signed date"
                        required
                      />
                    </div>
                    <div>
                      <Label className="text-sm font-medium">Signed Location *</Label>
                      <Input
                        placeholder="e.g. Ho Chi Minh City"
                        value={signedLocation}
                        onChange={(e) => setSignedLocation(e.target.value)}
                        className="h-11 mt-1"
                      />
                    </div>
                  </div>

                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                      <DatePicker
                        label="Start Date *"
                        value={startDate}
                        onChange={setStartDate}
                        placeholder="Select start date"
                        required
                      />
                    </div>
                    <div>
                      <DatePicker
                        label="End Date *"
                        value={endDate}
                        onChange={setEndDate}
                        placeholder="Select end date"
                        required
                        minDate={startDate}
                      />
                    </div>
                  </div>

                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                      <Label className="text-sm font-medium">Deposit Percent (%)</Label>
                      <Input
                        type="number"
                        min="0"
                        max="100"
                        value={depositPercent}
                        onChange={(e) => setDepositPercent(Number(e.target.value))}
                        className="h-11 mt-1"
                      />
                    </div>
                    <div>
                      <Label className="text-sm font-medium">Deposit Amount (VND)</Label>
                      <Input
                        type="number"
                        min="0"
                        value={depositAmount}
                        onChange={(e) => setDepositAmount(Number(e.target.value))}
                        className="h-11 mt-1"
                      />
                    </div>
                  </div>
                </TabsContent>

                {/* Representative Information Tab */}
                <TabsContent value="representative" className="space-y-5">
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                      <Label className="text-sm font-medium">Representative Name *</Label>
                      <Input
                        placeholder="Full name"
                        value={repName}
                        onChange={(e) => setRepName(e.target.value)}
                        className="h-11 mt-1"
                      />
                    </div>
                    <div>
                      <Label className="text-sm font-medium">Role/Position *</Label>
                      <Input
                        placeholder="e.g. Marketing Manager"
                        value={repRole}
                        onChange={(e) => setRepRole(e.target.value)}
                        className="h-11 mt-1"
                      />
                    </div>
                  </div>

                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                      <Label className="text-sm font-medium">Phone Number *</Label>
                      <Input
                        placeholder="0123456789"
                        value={repPhone}
                        onChange={(e) => setRepPhone(e.target.value)}
                        className="h-11 mt-1"
                      />
                    </div>
                    <div>
                      <Label className="text-sm font-medium">Email Address *</Label>
                      <Input
                        type="email"
                        placeholder="representative@company.com"
                        value={repEmail}
                        onChange={(e) => setRepEmail(e.target.value)}
                        className="h-11 mt-1"
                      />
                    </div>
                  </div>

                  <div>
                    <Label className="text-sm font-medium">Tax Number</Label>
                    <Input
                      placeholder="Tax identification number"
                      value={repTaxNumber}
                      onChange={(e) => setRepTaxNumber(e.target.value)}
                      className="h-11 mt-1"
                    />
                  </div>

                  <div className="pt-4 border-t">
                    <h3 className="text-md font-semibold mb-4">Banking Information</h3>
                    
                    <div className="space-y-4">
                      <div>
                        <Label className="text-sm font-medium">Bank Name</Label>
                        <Input
                          placeholder="e.g. Vietcombank"
                          value={repBankName}
                          onChange={(e) => setRepBankName(e.target.value)}
                          className="h-11 mt-1"
                        />
                      </div>

                      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                          <Label className="text-sm font-medium">Account Number</Label>
                          <Input
                            placeholder="Bank account number"
                            value={repBankAccount}
                            onChange={(e) => setRepBankAccount(e.target.value)}
                            className="h-11 mt-1"
                          />
                        </div>
                        <div>
                          <Label className="text-sm font-medium">Account Holder</Label>
                          <Input
                            placeholder="Account holder name"
                            value={repBankHolder}
                            onChange={(e) => setRepBankHolder(e.target.value)}
                            className="h-11 mt-1"
                          />
                        </div>
                      </div>
                    </div>
                  </div>
                </TabsContent>

                {/* Contract Terms Tab (Read-only summary) */}
                <TabsContent value="terms" className="space-y-5">
                  <div className="p-4 bg-gray-50 rounded-lg border">
                    <h3 className="text-md font-semibold mb-3">Scope of Work</h3>
                    {contractDetail.scope_of_work?.general_requirements && 
                     contractDetail.scope_of_work.general_requirements.length > 0 ? (
                      <ul className="list-disc list-inside space-y-1">
                        {contractDetail.scope_of_work.general_requirements.map((req: string, index: number) => (
                          <li key={index} className="text-sm text-gray-700">{req}</li>
                        ))}
                      </ul>
                    ) : (
                      <p className="text-sm text-gray-500">No general requirements defined</p>
                    )}
                  </div>

                  <div className="p-4 bg-gray-50 rounded-lg border">
                    <h3 className="text-md font-semibold mb-3">Financial Terms</h3>
                    <div className="space-y-2 text-sm">
                      <div className="flex justify-between">
                        <span className="text-gray-600">Model:</span>
                        <span className="font-medium">{contractDetail.financial_terms?.model || "N/A"}</span>
                      </div>
                      {contractDetail.financial_terms?.total_cost && (
                        <div className="flex justify-between">
                          <span className="text-gray-600">Total Cost:</span>
                          <span className="font-medium">{contractDetail.financial_terms.total_cost.toLocaleString()} VND</span>
                        </div>
                      )}
                    </div>
                  </div>

                  <div className="p-4 bg-gray-50 rounded-lg border">
                    <h3 className="text-md font-semibold mb-3">Legal Terms</h3>
                    {contractDetail.legal_terms?.breach_of_contract?.items && 
                     contractDetail.legal_terms.breach_of_contract.items.length > 0 ? (
                      <div className="space-y-2">
                        {contractDetail.legal_terms.breach_of_contract.items.map((item: any, index: number) => (
                          <div key={index} className="text-sm">
                            <p className="font-medium text-gray-700">{item.title}</p>
                            {item.compensation_percent && (
                              <p className="text-xs text-gray-500">Compensation: {item.compensation_percent}%</p>
                            )}
                          </div>
                        ))}
                      </div>
                    ) : (
                      <p className="text-sm text-gray-500">No legal terms defined</p>
                    )}
                  </div>

                  <div className="p-3 bg-amber-50 border border-amber-200 rounded-lg">
                    <p className="text-sm text-amber-800">
                      <strong>Note:</strong> Detailed contract terms (Scope of Work, Financial Terms, Legal Terms) cannot be edited here. 
                      For major changes, please create a new contract or contact support.
                    </p>
                  </div>
                </TabsContent>
              </Tabs>
            </CardContent>
          </Card>
        </motion.div>

        {/* Actions */}
        <motion.div variants={itemVariants} className="flex justify-between pt-4 border-t">
          <Button variant="outline" onClick={handleGoBack}>
            Cancel
          </Button>
          <Button onClick={handleSubmit} disabled={!isValid}>
            <FaSave className="mr-2" />
            Save Changes
          </Button>
        </motion.div>
      </motion.div>
    </div>
  );
};

export default EditContractPage;
